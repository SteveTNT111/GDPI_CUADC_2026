<launch>
  <!--
    runmain.launch — CUADC 2026 总启动文件
    启动内容：
      1. main.py        飞行主控（状态机 + 模式切换 + 起飞）
      2. camera_node     D435i 相机驱动
      3. detector_node   YOLO 目标检测
      4. geopose_node    大地坐标变换（可选）

    运行方式：
      roslaunch cuadc_vision runmain.launch
      roslaunch cuadc_vision runmain.launch auto_arm:=true auto_takeoff:=true
  -->

  <!-- ==================== 全局参数 ==================== -->
  <arg name="fps" default="30" />
  <arg name="enable_geopose" default="false" />
  <arg name="enable_auto_drop" default="false" />
  <arg name="yolo_model_path" default="$(find cuadc_vision)/models/best.onnx" />
  <arg name="yolo_device" default="cpu" />
  <arg name="yolo_conf_threshold" default="0.6" />
  <arg name="yolo_show_window" default="true" />
  <arg name="yolo_class_names" default="cylinder" />
  <arg name="yolo_target_classes" default="cylinder" />
  <arg name="yolo_cv_threads" default="1" />
  <arg name="yolo_omp_threads" default="8" />

  <!-- 自动抛投参数 -->
  <arg name="drop_pixel_threshold" default="20.0" />
  <arg name="drop_min_conf" default="0.6" />
  <arg name="drop_channel" default="9" />
  <arg name="drop_release_pwm" default="1900" />
  <arg name="drop_reset_pwm" default="1100" />
  <arg name="drop_hold_seconds" default="0.8" />
  <arg name="drop_cooldown" default="2.0" />

  <!-- 主控参数 -->
  <arg name="takeoff_altitude" default="10.0" />
  <arg name="auto_arm" default="false" />
  <arg name="auto_takeoff" default="false" />

  <!-- ==================== 1. 飞行主控 ==================== -->
  <node pkg="cuadc_vision"
        type="main.py"
        name="flight_controller"
        output="screen"
        required="true">
    <param name="takeoff_altitude" value="$(arg takeoff_altitude)" />
    <param name="auto_arm" value="$(arg auto_arm)" />
    <param name="auto_takeoff" value="$(arg auto_takeoff)" />
  </node>

  <!-- ==================== 2. D435i 相机 ==================== -->
  <node pkg="cuadc_vision"
        type="camera_node.py"
        name="camera_node"
        output="screen">
    <param name="fps" value="$(arg fps)" />
  </node>

  <!-- ==================== 3. YOLO 检测 ==================== -->
  <node pkg="cuadc_vision"
        type="detector_node.py"
        name="detector_node"
        output="screen">
    <env name="ULTRALYTICS_SKIP_REQUIREMENTS_CHECKS" value="1" />
    <env name="OMP_NUM_THREADS" value="$(arg yolo_omp_threads)" />
    <env name="MKL_NUM_THREADS" value="$(arg yolo_omp_threads)" />
    <env name="OMP_WAIT_POLICY" value="PASSIVE" />
    <env name="OMP_PROC_BIND" value="FALSE" />
    <param name="model_path" value="$(arg yolo_model_path)" />
    <param name="device" value="$(arg yolo_device)" />
    <param name="conf_threshold" value="$(arg yolo_conf_threshold)" />
    <param name="show_window" value="$(arg yolo_show_window)" />
    <param name="class_names" value="$(arg yolo_class_names)" />
    <param name="target_classes" value="$(arg yolo_target_classes)" />
    <param name="cv_threads" value="$(arg yolo_cv_threads)" />
  </node>

  <!-- ==================== 3b. 自动抛投（可选） ==================== -->
  <group if="$(arg enable_auto_drop)">
    <node pkg="cuadc_vision"
          type="auto_drop_node.py"
          name="auto_drop_node"
          output="screen">
      <param name="pixel_threshold" value="$(arg drop_pixel_threshold)" />
      <param name="min_conf" value="$(arg drop_min_conf)" />
      <param name="channel" value="$(arg drop_channel)" />
      <param name="release_pwm" value="$(arg drop_release_pwm)" />
      <param name="reset_pwm" value="$(arg drop_reset_pwm)" />
      <param name="hold_seconds" value="$(arg drop_hold_seconds)" />
      <param name="cooldown" value="$(arg drop_cooldown)" />
    </node>
  </group>

  <!-- ==================== 4. 大地坐标变换 ==================== -->
  <group if="$(arg enable_geopose)">
    <node pkg="cuadc_vision"
          type="geopose_node.py"
          name="geopose_node"
          output="screen" />
  </group>
</launch>
